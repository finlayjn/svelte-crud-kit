{
	"name": "@finlayjn/svelte-crud-kit",
	"version": "0.1.0",
	"description": "Headless-ish SvelteKit primitives for building internal CRUD admin tools. Built on daisyUI + Tailwind.",
	"author": "Finlay Nathan",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/finlayjn/svelte-crud-kit.git"
	},
	"homepage": "https://github.com/finlayjn/svelte-crud-kit#readme",
	"bugs": "https://github.com/finlayjn/svelte-crud-kit/issues",
	"keywords": [
		"svelte",
		"sveltekit",
		"crud",
		"admin",
		"datatable",
		"pagination",
		"tailwindcss",
		"daisyui"
	],
	"license": "MIT",
	"type": "module",
	"private": false,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./list": {
			"types": "./dist/list/index.d.ts",
			"default": "./dist/list/index.js"
		},
		"./state": {
			"types": "./dist/state/index.d.ts",
			"svelte": "./dist/state/index.js"
		},
		"./fields": {
			"types": "./dist/fields/index.d.ts",
			"svelte": "./dist/fields/index.js"
		}
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.0.0",
		"daisyui": "^5.0.0",
		"svelte": "^5.29.0",
		"tailwindcss": "^4.0.0",
		"valibot": "^1.0.0"
	},
	"peerDependenciesMeta": {
		"daisyui": {
			"optional": true
		},
		"tailwindcss": {
			"optional": true
		},
		"valibot": {
			"optional": true
		}
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/kit": "^2.65.0",
		"@sveltejs/package": "^2.5.4",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.1.18",
		"daisyui": "^5.5.18",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"publint": "^0.3.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"valibot": "^1.4.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
